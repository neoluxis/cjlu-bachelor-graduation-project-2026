{
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-draft",
      "command": "latexmk",
      "args": [
        "-interaction=nonstopmode",
        "-halt-on-error",
        "-xelatex",
        "-pdflatex=\"xelatex '\\def\\DRAFTMODE{} \\input %S'\"",
        "%DOC%"
      ]
    },
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-interaction=nonstopmode",
        "-halt-on-error",
        "-xelatex",
        "%DOC%"
      ]
    },
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-interaction=nonstopmode",
        "-halt-on-error",
        "%DOC%"
      ]
    },
    {
      "name": "biber",
      "command": "biber",
      "args": [
        "%DOCFILE%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk",
      "tools": [
        "latexmk"
      ]
    },
    {
      "name": "latexmk-draft",
      "tools": [
        "latexmk-draft"
      ]
    },
    {
      "name": "latexmk → biber → latexmk",
      "tools": [
        "latexmk",
        "biber",
        "latexmk"
      ]
    },
    {
      "name": "xelatex → biber → xelatex ×2",
      "tools": [
        "xelatex",
        "biber",
        "xelatex",
        "xelatex"
      ]
    }
  ],
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.autoBuild.interval": 2000,
  "latex-workshop.latex.outDir": "%DIR%",
  "latex-workshop.latexindent.path": "latexindent",
  "latex-workshop.latexindent.args": [
    "-w"
  ],
  "latex-workshop.latex.autoClean.run": "onBuild",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bcf",
    "*.blg",
    "*.bbl",
    "*.log",
    "*.run.xml",
    "*.synctex.gz",
    "*.out",
    "*.toc",
    "*.nav",
    "*.snm",
    "*.vrb",
    "*.fdb_latexmk",
    "*.fls",
    "*.lof",
    "*.lot",
    "*.idx",
    "*.ilg",
    "*.ind",
  ],
  "[latex]": {
    "editor.formatOnSave": true
  }
}
